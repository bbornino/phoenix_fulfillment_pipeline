<.header>
  Order {@order.order_number}
  <:actions>
    <.link href={~p"/orders/#{@order}/edit"}>
      <.button>Edit order</.button>
    </.link>
  </:actions>
</.header>

<.list>
  <:item title="Order number">{@order.order_number}</:item>
  
  <:item title="Customer name">{@order.customer_name}</:item>
  
  <:item title="Customer email">{@order.customer_email}</:item>
  
  <:item title="Status"><span style={status_color(@order.status)}>{@order.status}</span></:item>
  
  <:item title="Priority">{@order.priority}</:item>
  
  <:item title="Notes">{@order.notes}</:item>
  
  <:item title="Requires signature">{@order.requires_signature}</:item>
  
  <:item title="Estimated ship date">{@order.estimated_ship_date}</:item>
  
  <:item title="Warehouse">
    {if @order.warehouse, do: @order.warehouse.name, else: "Unknown"}
  </:item>
  
  <:item title="Carrier">
    {if @order.carrier, do: @order.carrier.name, else: "Not assigned"}
  </:item>
  
  <:item title="Tracking number">
    {if @order.tracking_number, do: @order.tracking_number, else: "Not assigned"}
  </:item>
</.list>
 <.link navigate={~p"/orders"}>Back to orders</.link>
